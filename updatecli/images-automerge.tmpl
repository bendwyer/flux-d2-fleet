---
name: "Update container image versions (auto-merge)"

scms:
  fleet:
    kind: github
    spec:
      owner: {{ .github.owner }}
      repository: {{ .github.repository }}
      branch: main
      user: updatecli-bot
      email: updatecli@users.noreply.github.com

sources:
  {{- range .images }}
  {{ .name }}-tag:
    kind: dockerimage
    spec:
      image: {{ .image }}
      {{- if .tagfilter }}
      tagfilter: '{{ .tagfilter }}'
      {{- end }}
      versionfilter:
        kind: semver
        pattern: "{{ .safe }}"
  {{- if .needs_digest }}
  {{ .name }}-digest:
    kind: dockerdigest
    spec:
      image: {{ .image }}
      tag: '{{"{{"}} source "{{ .name }}-tag" {{"}}"}}'
      hidetag: true
    dependson:
      - {{ .name }}-tag
  {{- end }}
  {{- end }}

targets:
  {{- range .images }}
  {{- $img := . }}
  {{- range .tenants }}
  {{ .name }}-{{ $img.name }}-tag:
    name: "Update {{ $img.name }} tag in {{ .name }} versions"
    kind: yaml
    scmid: fleet
    sourceid: {{ $img.name }}-tag
    spec:
      file: tenants/{{ .name }}/versions.yaml
      key: "$.spec.inputs[0].{{ .key }}.tag"
  {{- if $img.needs_digest }}
  {{ .name }}-{{ $img.name }}-digest:
    name: "Update {{ $img.name }} digest in {{ .name }} versions"
    kind: yaml
    scmid: fleet
    sourceid: {{ $img.name }}-digest
    transformers:
      - trimprefix: "@"
    spec:
      file: tenants/{{ .name }}/versions.yaml
      key: "$.spec.inputs[0].{{ .key }}.digest"
  {{- end }}
  {{- end }}
  {{- end }}

actions:
  default:
    kind: github/pullrequest
    scmid: fleet
    title: 'chore(deps): update container images'
    spec:
      automerge: true
      mergemethod: squash
      labels:
        - dependencies
